# ========== DeepSeek API ==========
# 在 https://platform.deepseek.com/ 获取你的 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_SKIP_HEALTHCHECK=0

# ========== Neo4j 知识图谱 ==========
# 首次运行会自动创建，请设置安全密码
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j_password

# ========== Flask ==========
# 请修改为随机字符串（可以用 python -c "import secrets; print(secrets.token_hex(32))" 生成）
FLASK_SECRET_KEY=change_me_flask_secret
FLASK_DEBUG=0
PORT=5000

# ========== MySQL（Docker 默认启用；本地开发可留空改用 SQLite）==========
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=semiconductor_kg
MYSQL_USER=kg_user
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_ROOT_PASSWORD=change_me_mysql_root

# 或直接指定完整 URI（优先级最高）
# SQLALCHEMY_DATABASE_URI=mysql+pymysql://kg_user:pass@mysql:3306/semiconductor_kg?charset=utf8mb4

# ========== Claude Code 流水线 ==========
PIPELINE_INBOX=automation/inbox
PIPELINE_OUTBOX=automation/outbox
PIPELINE_AUTO_APPLY=0
